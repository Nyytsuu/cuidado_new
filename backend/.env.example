# Copy this file to .env and fill in real values. NEVER commit .env to git.

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Mailer (Gmail app password or SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_SERVICE=gmail

# reCAPTCHA
RECAPTCHA_SECRET_KEY=your-recaptcha-secret

# News API
NEWS_API_KEY=your-news-api-key

# CORS — comma-separated frontend origins (leave blank to allow all, for dev only)
# Example: ALLOWED_ORIGINS=https://cuidado.example.com,https://www.cuidado.example.com
ALLOWED_ORIGINS=

# Supabase Storage — required on Render (ephemeral disk wipes uploaded files on restart).
# 1. Supabase dashboard → Storage → Create bucket named "profile-pictures" → set to Public
# 2. Supabase dashboard → Settings → API → copy Project URL and service_role key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
